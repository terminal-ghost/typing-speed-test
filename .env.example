# Production Configuration
# IMPORTANT: Copy this file to .env and fill in your settings before deploying

# Security Configuration (REQUIRED for production)
SECRET_KEY=your-super-secret-key-change-this-in-production-make-it-long-and-random

# Email Configuration
# To enable email notifications, fill in your email settings

# Gmail SMTP Configuration (recommended)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password  # Use Gmail App Password, not your regular password
MAIL_DEFAULT_SENDER=Keyzio <no-reply@keyzio.shop>

# Instructions for Gmail App Password:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to Google Account settings > Security > App passwords
# 3. Generate a new app password for this application
# 4. Use the generated 16-character password as MAIL_PASSWORD

# Alternative SMTP servers:
# Outlook/Hotmail: smtp-mail.outlook.com, port 587
# Yahoo: smtp.mail.yahoo.com, port 587
# Custom SMTP: Use your provider's settings
